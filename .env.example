# ===========================================
# CRAB MONITORING SYSTEM - Environment Config
# ===========================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crab_monitoring
DB_USER=crab_admin
DB_PASSWORD=crab_secure_2024
DATABASE_URL=postgresql+asyncpg://crab_admin:crab_secure_2024@localhost:5432/crab_monitoring

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your-super-secret-key-change-in-production
API_DEBUG=false

# Camera Configuration
CAMERA_1_INDEX=0
CAMERA_2_INDEX=1
CAMERA_1_WIDTH=1280
CAMERA_1_HEIGHT=720
CAMERA_2_WIDTH=1280
CAMERA_2_HEIGHT=720
CAMERA_FPS=30

# AI Models
YOLO_MODEL_PATH=ai_models/weights/yolov8_crabs.pt
SPECIES_MODEL_PATH=ai_models/weights/species_classifier.pt
GENDER_MODEL_PATH=ai_models/weights/gender_classifier.pt
HEALTH_MODEL_PATH=ai_models/weights/health_classifier.pt
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45

# Storage
IMAGE_STORAGE_PATH=storage/images
MODEL_STORAGE_PATH=storage/models

# Streaming
STREAM_FPS=15
STREAM_QUALITY=85

# Scraping
SCRAPING_INTERVAL_HOURS=24
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/crab_monitor.log
