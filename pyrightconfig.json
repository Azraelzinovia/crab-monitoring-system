{
  "pythonVersion": "3.11",
  "pythonPlatform": "Linux",
  "venvPath": ".",
  "venv": ".venv",
  "include": [
    "backend",
    "ai_models",
    "scraping",
    "scripts"
  ],
  "exclude": [
    "frontend",
    "**/__pycache__",
    "**/node_modules",
    "**/.git"
  ],
  "reportMissingImports": "none",
  "reportMissingModuleSource": "none",
  "reportMissingTypeStubs": "none",
  "reportUnknownMemberType": "none",
  "reportAttributeAccessIssue": "none",
  "typeCheckingMode": "off"
}
