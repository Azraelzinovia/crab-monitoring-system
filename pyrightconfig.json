{
  "pythonVersion": "3.11",
  "pythonPlatform": "Linux",
  "venvPath": ".",
  "venv": ".venv",
  "executionEnvironments": [
    {
      "root": "backend",
      "extraPaths": ["backend"]
    },
    {
      "root": "ai_models",
      "extraPaths": ["ai_models", "backend"]
    },
    {
      "root": "scraping",
      "extraPaths": ["scraping", "backend"]
    },
    {
      "root": "scripts",
      "extraPaths": ["scripts", "backend"]
    }
  ],
  "include": [
    "backend",
    "ai_models",
    "scraping",
    "scripts"
  ],
  "exclude": [
    "frontend",
    "**/__pycache__",
    "**/node_modules",
    "**/.git"
  ],
  "reportMissingImports": "none",
  "reportMissingModuleSource": "none",
  "reportMissingTypeStubs": "none",
  "typeCheckingMode": "basic"
}
