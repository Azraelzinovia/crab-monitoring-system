{
  "pythonVersion": "3.11",
  "pythonPlatform": "Linux",
  "venvPath": ".",
  "venv": ".venv",
  "include": [
    "backend",
    "ai_models",
    "scraping",
    "scripts"
  ],
  "exclude": [
    "frontend",
    "**/__pycache__",
    "**/node_modules"
  ],
  "reportMissingModuleSource": "none",
  "reportMissingImports": "warning",
  "typeCheckingMode": "basic"
}
